# === Redis (Upstash) ===
REDIS_URL=rediss://default:SENHA@HOST.upstash.io:6379

# === Servidor (local ou Fly injeta PORT=8080) ===
PORT=8080

# TCP opcional em dev (desligado no Fly via fly.toml)
ENABLE_TCP_SERVER=true
CHAT_HOST=0.0.0.0
CHAT_PORT=9000

HISTORY_MAX=500
PUBSUB_CHANNEL=chat:broadcast
