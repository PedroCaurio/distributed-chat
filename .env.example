# === Servidor de chat (Render/VPS/Fly/etc.) ===
# URL do Redis (Render Key Value, Upstash, Redis Cloud, etc.)
REDIS_URL=redis://default:SENHA@HOST:6379

# Bind do processo Python (dentro do container/VM)
CHAT_HOST=0.0.0.0
CHAT_PORT=9000

# Histórico persistido na lista Redis chat:history
HISTORY_MAX=500

# Canal pub/sub entre instâncias do servidor
PUBSUB_CHANNEL=chat:broadcast

# Opcional: tamanho de buffer de leitura TCP (bytes)
# TCP_READ_BUFFER=65536

# === Proxy local (máquina do usuário final) ===
# Teste local: aponte para o servidor na mesma máquina
CHAT_SERVER_HOST=127.0.0.1
CHAT_SERVER_PORT=9000

# Produção: host público do servidor TCP (não use localhost na avaliação)
# CHAT_SERVER_HOST=seu-servidor.tcp.exemplo.com

# API HTTP local servindo o front-end
PROXY_HTTP_HOST=127.0.0.1
PROXY_HTTP_PORT=5000

# CORS: origens do front (Vite dev usa 5173 por padrão se omitido)
# PROXY_CORS_ORIGINS=http://localhost:5173,https://seu-app.vercel.app
