# Copie para .env e preencha REDIS_URL (Upstash).

# Logs didáticos no terminal (threads, TCP, funções) — use na apresentação
DEMO_LOGS=1
# Scripts LOCAL_* e testes LOCAL_* leem este arquivo via python-dotenv (se configurado) ou variáveis do shell.

# === Redis (Upstash) — obrigatório ===
REDIS_URL=rediss://default:SENHA@HOST.upstash.io:6379

# === Cliente HTTP (navegador) ===
PORT=8080
PROXY_HTTP_HOST=0.0.0.0

# === Servidor TCP (chat) ===
CHAT_SERVER_HOST=127.0.0.1
CHAT_SERVER_PORT=9000
CHAT_HOST=0.0.0.0

HISTORY_MAX=500
PUBSUB_CHANNEL=chat:broadcast

# === Front (só LOCAL_front.ps1 / npm run dev) ===
# frontend/.env: VITE_API_URL=/api
