# === Redis (Upstash ou Render Key Value) ===
REDIS_URL=rediss://default:SENHA@HOST.upstash.io:6379

# === Servidor unificado (HTTP + TCP opcional) ===
# Render define PORT automaticamente (ex.: 10000)
PORT=10000
HTTP_PORT=10000

# TCP interno (desligado no Render; útil em dev local)
ENABLE_TCP_SERVER=true
CHAT_HOST=0.0.0.0
CHAT_PORT=9000

HISTORY_MAX=500
PUBSUB_CHANNEL=chat:broadcast

# CORS extra (opcional; em produção front e API são mesma origem)
# CORS_ORIGINS=https://seu-dominio.vercel.app

# === Front-end (somente desenvolvimento local) ===
# VITE_API_URL=http://127.0.0.1:10000
# ou use proxy Vite: VITE_API_URL=/api
